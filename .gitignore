# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environment
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/

# IDE
.idea/
.vscode/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
outputs/logs/*

# Keep source data for reproducibility
# data/raw/ is intentionally versioned
# data/external/ is intentionally versioned

# Ignore generated intermediate and processed data
data/interim/*
data/processed/*
!data/interim/.gitkeep
!data/processed/.gitkeep

# Ignore generated outputs
outputs/figures/*
outputs/tables/*
outputs/models/*
!outputs/figures/.gitkeep
!outputs/tables/.gitkeep
!outputs/models/.gitkeep

# Keep curated showcase assets for README
!docs/
!docs/assets/
!docs/assets/figures/
!docs/assets/tables/

# Testing / caches
.pytest_cache/
.mypy_cache/
coverage.xml
htmlcov/